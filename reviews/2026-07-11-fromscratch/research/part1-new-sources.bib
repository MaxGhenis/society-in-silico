% --- Correction #3: the true source of the "random walk beat the CBO" finding.
% The manuscript attributes this to the Berkeley (Inayatali) thesis; it is actually
% Kliesen & Thornton (2012), quoted in that thesis's literature review. Their analysis
% covers CBO forecasts 1976-2007 over short and medium horizons.
@article{kliesen2012cbo,
  author  = {Kliesen, Kevin L. and Thornton, Daniel L.},
  title   = {How Good Are the Government's Deficit and Debt Projections and Should We Care?},
  journal = {Federal Reserve Bank of St.\ Louis Review},
  year    = {2012},
  volume  = {94},
  number  = {1},
  pages   = {21--39},
  url     = {https://research.stlouisfed.org/publications/review/2012/01/01/how-good-are-the-governments-deficit-and-debt-projections-and-should-we-care}
}


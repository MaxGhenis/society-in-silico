---
import Layout from '../layouts/Layout.astro';
import { bookStructure, getDraftStats } from '../lib/book';

const stats = getDraftStats();
const roman = ['I', 'II', 'III', 'IV', 'V', 'VI'];
const firstChapter = bookStructure.frontMatter[0];
---

<Layout
  title="Society in Silico — a book by Max Ghenis"
  description="Simulating futures to build the one we want. Teaching computers the law, building a simulated country to run it on, and grading the predictions against reality — a book drafted in public."
>
  <nav class="topbar">
    <a href="/" class="eyebrow" style="color: var(--ink)">Society <em style="font-family: var(--font-body); font-style: italic; text-transform: none; letter-spacing: 0">in silico</em></a>
    <div class="flex items-center gap-5 text-sm" style="font-family: var(--font-display)">
      <a href="#contents">Contents</a>
      <a href={`/book/${firstChapter.slug}`}>Read</a>
      <button class="theme-toggle" aria-label="Toggle dark mode">◐</button>
    </div>
  </nav>

  <!-- ————— hero ————— -->
  <header class="mx-auto max-w-5xl px-5 pt-16 pb-10 md:pt-24">
    <p class="eyebrow eyebrow--green mb-6">A book in progress · draft in public · 2026</p>

    <h1 class="wordmark text-[17vw] leading-[0.9] md:text-[7.5rem]">
      Society<br /><em>in silico</em>
    </h1>

    <p class="mt-8 max-w-xl text-lg leading-relaxed" style="color: var(--ink-2)">
      {bookStructure.subtitle}. The story of teaching computers the law, building a
      simulated country to run it on, and grading the predictions against reality —
      and of the fork that decides who the machinery serves.
    </p>

    <div class="mt-8 flex flex-wrap items-center gap-3">
      <a class="btn btn--primary" href={`/book/${firstChapter.slug}`}>Start reading</a>
      <a class="btn btn--ghost" href="#contents">Contents</a>
      <span class="tick ml-2">free to read online</span>
    </div>
  </header>

  <!-- ————— signature: the aggregation error, live ————— -->
  <section class="mx-auto max-w-5xl px-5 pb-16" aria-label="Why model individuals">
    <div class="field-wrap">
      <canvas id="field" class="block h-[300px] w-full md:h-[360px]" aria-hidden="true"></canvas>
      <div class="flex flex-wrap items-center justify-between gap-3 border-t px-4 py-3" style="border-color: var(--hairline-soft)">
        <div class="field-toggle" role="group" aria-label="View households as">
          <button id="btn-avg" aria-pressed="false">the average</button>
          <button id="btn-dist" aria-pressed="true">the distribution</button>
        </div>
        <p id="field-caption" class="text-sm italic" style="color: var(--ink-2); font-family: var(--font-body)">
          Every dot is a household. Same average income either way — but only one view shows who
          <span style="color: var(--amber)">falls off a benefit cliff</span>.
        </p>
      </div>
    </div>
    <p class="mt-4 max-w-2xl text-sm leading-relaxed" style="color: var(--ink-3)">
      In 1957, Guy Orcutt noticed that national averages can be identical while the
      lives underneath them differ completely — so he proposed simulating the
      households instead. This book is about what happened when that idea finally got
      the machinery it needed, and the case it builds is one sentence long: history
      should have auditors, not an author.
    </p>
  </section>

  <!-- ————— the rule ————— -->
  <section class="border-y" style="border-color: var(--hairline); background: var(--paper-2)">
    <div class="mx-auto max-w-5xl px-5 py-14">
      <p class="eyebrow mb-4">The discipline the book runs on</p>
      <blockquote class="max-w-3xl text-2xl leading-snug md:text-[1.7rem]" style="font-family: var(--font-body)">
        A simulation is admissible only where its verification chain terminates in
        ground truth — <span style="color: var(--green)">a rule checked against the statute</span>,
        <span style="color: var(--green)">a population checked against the census</span>,
        <span style="color: var(--green)">a forecast graded when the official number lands</span>.
      </blockquote>
      <p class="mt-5 text-sm" style="color: var(--ink-3)">
        Chapter 3 states it; chapters 9–13 build the machinery that enforces it — merge-blocking
        source checks, oracle races against the models governments already trust, and a public
        scoreboard that waits for reality.
      </p>
    </div>
  </section>

  <!-- ————— contents ————— -->
  <section id="contents" class="mx-auto max-w-5xl px-5 py-16">
    <div class="mb-10 flex flex-wrap items-baseline justify-between gap-3">
      <h2 class="eyebrow" style="font-size: 0.8125rem">Contents</h2>
      <span class="ledger-meta">{stats.chapters} chapters · {stats.words.toLocaleString('en-US')} words</span>
    </div>

    <div class="mb-8">
      {bookStructure.frontMatter.map((ch) => (
        <a class="ledger-row" href={`/book/${ch.slug}`}>
          <span class="ledger-num">—</span>
          <span class="ledger-title">{ch.title}</span>
          <span class="ledger-meta">{Math.ceil((ch.words ?? 0) / 200)} min</span>
        </a>
      ))}
    </div>

    <div class="grid gap-x-14 gap-y-10 md:grid-cols-2">
      {bookStructure.parts.map((part) => (
        <div>
          <div class="mb-2 flex items-baseline justify-between border-b-2 pb-2" style="border-color: var(--ink)">
            <h3 class="eyebrow" style="color: var(--ink)">
              Part {roman[part.number - 1]} · {part.title}
            </h3>
          </div>
          {part.chapters.map((ch) => (
            <a class="ledger-row" href={`/book/${ch.slug}`}>
              <span class="ledger-num">{String(ch.chapterNumber).padStart(2, '0')}</span>
              <span class="ledger-title">{ch.title}</span>
              <span class="ledger-meta">{Math.ceil((ch.words ?? 0) / 200)} min</span>
            </a>
          ))}
        </div>
      ))}
    </div>
  </section>

  <!-- ————— the draft ledger: the book's discipline, applied to itself ————— -->
  <section class="border-t" style="border-color: var(--hairline)">
    <div class="mx-auto max-w-5xl px-5 py-14">
      <div class="grid gap-10 md:grid-cols-[1.2fr_1fr]">
        <div>
          <p class="eyebrow mb-4">A draft, graded like its subject</p>
          <p class="max-w-md leading-relaxed" style="color: var(--ink-2)">
            The book argues that claims should carry their verification state, so this
            draft carries its own. These figures are computed from the manuscript at
            every build; the pending marks are visible in the text where they sit.
          </p>
          <form
            action="https://buttondown.com/api/emails/embed-subscribe/maxghenis"
            method="post"
            target="_blank"
            class="mt-8 flex max-w-md gap-2"
          >
            <input
              type="email"
              name="email"
              required
              placeholder="you@example.com"
              class="w-full border px-3 py-2 text-sm"
              style="border-color: var(--hairline); background: var(--card); color: var(--ink); font-family: var(--font-mono); border-radius: 2px"
            />
            <button type="submit" class="btn btn--ghost" style="white-space: nowrap">Follow the draft</button>
          </form>
          <p class="mt-2 text-xs" style="color: var(--ink-3); font-family: var(--font-mono)">
            occasional updates as the draft hardens · no spam
          </p>
        </div>

        <dl class="self-start border text-sm" style="border-color: var(--hairline); background: var(--card); border-radius: 4px; font-family: var(--font-mono)">
          {[
            { k: 'chapters', v: `${stats.chapters} across ${stats.parts} parts`, state: 'done' },
            { k: 'words', v: stats.words.toLocaleString('en-US'), state: 'done' },
            { k: 'citations pending', v: String(stats.citationsPending), state: 'pending' },
            { k: 'facts to re-verify', v: String(stats.verifyMarks), state: 'pending' },
            { k: 'forecasts resolved', v: `${stats.forecastsResolved} — graded when reality arrives`, state: 'open' },
          ].map((row, i) => (
            <div
              class="flex items-baseline justify-between gap-6 px-4 py-2.5"
              style={i > 0 ? 'border-top: 1px solid var(--hairline-soft)' : ''}
            >
              <dt class={`tick ${row.state === 'pending' ? 'tick--pending' : row.state === 'open' ? 'tick--open' : ''}`}>{row.k}</dt>
              <dd style="color: var(--ink)">{row.v}</dd>
            </div>
          ))}
        </dl>
      </div>
    </div>
  </section>

  <!-- ————— author / colophon ————— -->
  <footer class="border-t" style="border-color: var(--hairline); background: var(--paper-2)">
    <div class="mx-auto flex max-w-5xl flex-wrap items-center justify-between gap-6 px-5 py-10">
      <div>
        <p style="font-family: var(--font-display); font-weight: 650">{bookStructure.author}</p>
        <p class="mt-1 max-w-sm text-sm" style="color: var(--ink-2)">
          Builder of PolicyEngine, the Axiom Foundation, and the Thesis Institute —
          writing this book in public from Washington, DC.
        </p>
      </div>
      <div class="flex gap-5 text-sm" style="font-family: var(--font-mono)">
        <a href="https://maxghenis.com" style="color: var(--green)">maxghenis.com</a>
        <a href="https://github.com/MaxGhenis/society-in-silico" style="color: var(--green)">source</a>
        <a href="https://x.com/MaxGhenis" style="color: var(--green)">x</a>
        <a href="https://github.com/MaxGhenis" style="color: var(--green)">github</a>
      </div>
    </div>
    <div class="mx-auto max-w-5xl px-5 pb-8">
      <p class="text-xs" style="color: var(--ink-3); font-family: var(--font-mono)">
        © {new Date().getFullYear()} Max Ghenis · text CC BY-NC 4.0 · set in Literata &amp; Archivo ·
        draft — some of what you read will look different in two years; between drafts, it already does
      </p>
    </div>
  </footer>

  <!-- ————— the field ————— -->
  <script is:inline>
    (function () {
      const canvas = document.getElementById('field');
      if (!canvas) return;
      const ctx = canvas.getContext('2d');
      const btnAvg = document.getElementById('btn-avg');
      const btnDist = document.getElementById('btn-dist');
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      const N = 1600;
      const dots = [];
      // Deterministic pseudo-random: same society every visit.
      let seed = 20261957;
      function rand() {
        seed = (seed * 1103515245 + 12345) % 2147483648;
        return seed / 2147483648;
      }

      // Income-ish distribution: lognormal-ish via sum of uniforms, plus a cliff band.
      for (let i = 0; i < N; i++) {
        const u = (rand() + rand() + rand()) / 3; // bell-ish 0..1
        const skewed = Math.pow(u, 1.6); // skew low
        dots.push({
          x: rand(),
          yDist: skewed,
          cliff: skewed > 0.30 && skewed < 0.36 && rand() < 0.5,
          jitter: rand() * 2 - 1,
          size: 1 + rand() * 1.4,
        });
      }

      let t = 1; // 0 = average view, 1 = distribution view
      let target = 1;
      let raf = null;

      function colors() {
        const styles = getComputedStyle(document.documentElement);
        return {
          ink3: styles.getPropertyValue('--ink-3').trim(),
          green: styles.getPropertyValue('--green').trim(),
          amber: styles.getPropertyValue('--amber').trim(),
          hairline: styles.getPropertyValue('--hairline').trim(),
        };
      }

      function draw() {
        const dpr = window.devicePixelRatio || 1;
        const w = canvas.clientWidth;
        const h = canvas.clientHeight;
        if (canvas.width !== w * dpr) {
          canvas.width = w * dpr;
          canvas.height = h * dpr;
        }
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        ctx.clearRect(0, 0, w, h);
        const c = colors();

        const pad = 28;
        const meanY = h * 0.5;

        // The mean line, always present: what the aggregate sees.
        ctx.strokeStyle = c.hairline;
        ctx.setLineDash([4, 5]);
        ctx.beginPath();
        ctx.moveTo(pad, meanY);
        ctx.lineTo(w - pad, meanY);
        ctx.stroke();
        ctx.setLineDash([]);

        for (const d of dots) {
          const x = pad + d.x * (w - pad * 2);
          const yD = pad + (1 - d.yDist) * (h - pad * 2);
          const yA = meanY + d.jitter * 5;
          const y = yA + (yD - yA) * t;
          const isCliff = d.cliff && t > 0.55;
          ctx.globalAlpha = 0.4 + 0.45 * t * (d.yDist < 0.85 ? 1 : 0.7);
          ctx.fillStyle = isCliff ? c.amber : t > 0.5 ? c.green : c.ink3;
          ctx.beginPath();
          ctx.arc(x, y, d.size * (0.8 + 0.5 * t), 0, Math.PI * 2);
          ctx.fill();
        }
        ctx.globalAlpha = 1;

        // Axis label
        ctx.fillStyle = c.ink3;
        ctx.font = '10px "IBM Plex Mono", monospace';
        ctx.fillText(t > 0.5 ? 'household income →' : 'the average (identical either way)', pad, h - 10);
      }

      function step() {
        const d = target - t;
        if (Math.abs(d) < 0.004) {
          t = target;
          draw();
          raf = null;
          return;
        }
        t += d * 0.07;
        draw();
        raf = requestAnimationFrame(step);
      }

      function go(next) {
        target = next;
        btnAvg.setAttribute('aria-pressed', String(next === 0));
        btnDist.setAttribute('aria-pressed', String(next === 1));
        if (reduced) {
          t = next;
          draw();
          return;
        }
        if (!raf) raf = requestAnimationFrame(step);
      }

      btnAvg.addEventListener('click', () => go(0));
      btnDist.addEventListener('click', () => go(1));
      window.addEventListener('resize', draw);

      // Opening move: settle from the average into the distribution, once.
      if (reduced) {
        t = 1;
        draw();
      } else {
        t = 0;
        draw();
        setTimeout(() => go(1), 600);
      }

      // Redraw on theme change (colors come from CSS variables).
      new MutationObserver(draw).observe(document.documentElement, {
        attributes: true,
        attributeFilter: ['data-theme'],
      });
    })();
  </script>
</Layout>

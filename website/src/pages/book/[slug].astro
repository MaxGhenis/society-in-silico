---
import Layout from '../../layouts/Layout.astro';
import {
  bookStructure,
  getAllChapters,
  getChapterBySlug,
  getChapterNavigation,
  getChapterPosition,
} from '../../lib/book';
import { renderChapter } from '../../lib/reader';

export function getStaticPaths() {
  return getAllChapters().map((chapter) => ({ params: { slug: chapter.slug } }));
}

const { slug } = Astro.params;
const chapter = getChapterBySlug(slug);
if (!chapter) {
  return Astro.redirect('/book');
}

const { htmlContent, footnotesHtml, refsHtml, readingTime, wordCount } = renderChapter(chapter.file);
const { prev, next } = getChapterNavigation(slug);
const position = getChapterPosition(slug);
const roman = ['I', 'II', 'III', 'IV', 'V', 'VI'];
const partLabel = chapter.partNumber
  ? `Part ${roman[chapter.partNumber - 1]} - ${chapter.part}`
  : 'Front matter';
const chapterLabel = chapter.chapterNumber ? `Chapter ${chapter.chapterNumber}` : '';
---

<Layout
  title={`${chapter.title} — Society in Silico`}
  description={`Read "${chapter.title}" from Society in Silico by ${bookStructure.author}.`}
>
  <nav class="topbar">
    <a href="/book" class="flex items-center gap-2 text-sm" style="font-family: var(--font-display)">
      <span aria-hidden="true">←</span> Contents
    </a>
    <span class="eyebrow hidden sm:block">{partLabel}</span>
    <div class="flex items-center gap-3">
      <span class="ledger-meta hidden md:inline">{position.current}/{position.total}</span>
      <button class="theme-toggle" aria-label="Toggle dark mode">◐</button>
    </div>
  </nav>

  <div class="h-0.5 w-full" style="background: var(--hairline-soft)">
    <div id="reading-progress" class="h-full" style="width: 0%; background: var(--green)"></div>
  </div>

  <main class="mx-auto max-w-[44rem] px-5 pb-24">
    <header class="pb-8 pt-14 md:pt-20">
      <p class="eyebrow eyebrow--green">{chapterLabel || partLabel}</p>
      <h1
        class="mt-4 text-4xl leading-tight md:text-[2.75rem]"
        style="font-family: var(--font-body); font-weight: 560; letter-spacing: -0.01em"
      >
        {chapter.title}
      </h1>
      <p class="ledger-meta mt-5">
        {wordCount.toLocaleString('en-US')} words · {readingTime} min ·
        <span class="tick" style="display:inline-flex; margin-left:0.35rem">draft, July 2026</span>
      </p>
      <hr class="mt-8 border-0" style="border-top: 1px solid var(--hairline)" />
    </header>

    <article id="article-content">
      <div class="prose-reader" set:html={htmlContent} />
      <Fragment set:html={footnotesHtml} />
      <Fragment set:html={refsHtml} />
    </article>

    <nav class="mt-16 grid gap-3 border-t pt-8 md:grid-cols-2" style="border-color: var(--hairline)" aria-label="Chapter navigation">
      {prev ? (
        <a
          id="nav-prev"
          href={`/book/${prev.slug}`}
          class="group block border p-4"
          style="border-color: var(--hairline); border-radius: 4px; text-decoration: none; color: var(--ink)"
        >
          <span class="eyebrow">← Previous</span>
          <span class="mt-1 block" style="font-family: var(--font-body)">{prev.title}</span>
        </a>
      ) : (
        <span></span>
      )}
      {next ? (
        <a
          id="nav-next"
          href={`/book/${next.slug}`}
          class="group block border p-4 text-right"
          style="border-color: var(--hairline); border-radius: 4px; text-decoration: none; color: var(--ink)"
        >
          <span class="eyebrow">Next →</span>
          <span class="mt-1 block" style="font-family: var(--font-body)">{next.title}</span>
        </a>
      ) : (
        <span></span>
      )}
    </nav>

    <p class="ledger-meta mt-10 text-center">
      <a href="/" style="color: var(--ink-3); text-decoration: none">Society <em>in silico</em></a>
      · draft in public ·
      <a href="https://github.com/MaxGhenis/society-in-silico" style="color: var(--green); text-decoration: none">source</a>
    </p>
  </main>

  <style is:global>
    .prose-reader .cite,
    .prose-reader .concept {
      position: relative;
    }
    .prose-reader .cite::after,
    .prose-reader .concept::after {
      content: attr(data-tip);
      position: absolute;
      bottom: calc(100% + 6px);
      left: 50%;
      transform: translateX(-50%);
      background: var(--ink);
      color: var(--paper);
      font-family: var(--font-mono);
      font-size: 0.7rem;
      line-height: 1.4;
      padding: 0.4em 0.7em;
      border-radius: 3px;
      white-space: nowrap;
      max-width: 280px;
      z-index: 60;
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transition: opacity 120ms ease;
    }
    .prose-reader .concept::after { white-space: normal; width: max-content; }
    .prose-reader .cite:hover::after,
    .prose-reader .concept:hover::after {
      opacity: 1;
      visibility: visible;
    }
    .prose-reader .cite[data-url]:not([data-url=""]) { cursor: pointer; }
  </style>

  <script>
    function updateReadingProgress() {
      const article = document.getElementById('article-content');
      const bar = document.getElementById('reading-progress');
      if (!article || !bar) return;
      const progress = Math.min(
        Math.max((window.scrollY - article.offsetTop + window.innerHeight * 0.6) / article.offsetHeight, 0),
        1
      );
      bar.style.width = `${progress * 100}%`;
    }
    window.addEventListener('scroll', updateReadingProgress, { passive: true });
    updateReadingProgress();

    document.addEventListener('keydown', (e) => {
      if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return;
      if (e.key === 'ArrowLeft') (document.getElementById('nav-prev') as HTMLAnchorElement | null)?.click();
      if (e.key === 'ArrowRight') (document.getElementById('nav-next') as HTMLAnchorElement | null)?.click();
    });

    document.querySelectorAll('.cite').forEach((cite) => {
      cite.addEventListener('click', () => {
        const url = (cite as HTMLElement).dataset.url;
        if (url) window.open(url, '_blank', 'noopener');
      });
    });
  </script>
</Layout>

---
import Layout from '../../layouts/Layout.astro';
import { bookStructure, getDraftStats } from '../../lib/book';

const stats = getDraftStats();
const roman = ['I', 'II', 'III', 'IV', 'V', 'VI'];
---

<Layout title="Contents — Society in Silico" description="Table of contents for Society in Silico by Max Ghenis — read the draft online.">
  <nav class="topbar">
    <a href="/" class="eyebrow" style="color: var(--ink)">Society <em style="font-family: var(--font-body); font-style: italic; text-transform: none; letter-spacing: 0">in silico</em></a>
    <button class="theme-toggle" aria-label="Toggle dark mode">◐</button>
  </nav>

  <main class="mx-auto max-w-3xl px-5 pb-24 pt-14">
    <header class="mb-10">
      <p class="eyebrow eyebrow--green mb-3">Contents</p>
      <h1 class="wordmark text-4xl md:text-5xl">Society<br /><em>in silico</em></h1>
      <p class="ledger-meta mt-4">
        {stats.chapters} chapters · {stats.parts} parts · {stats.words.toLocaleString('en-US')} words · a draft in public
      </p>
    </header>

    <section class="mb-10">
      {bookStructure.frontMatter.map((ch) => (
        <a class="ledger-row" href={`/book/${ch.slug}`}>
          <span class="ledger-num">—</span>
          <span class="ledger-title">{ch.title}</span>
          <span class="ledger-meta">{Math.ceil((ch.words ?? 0) / 200)} min</span>
        </a>
      ))}
    </section>

    {bookStructure.parts.map((part) => (
      <section class="mb-10">
        <h2 class="eyebrow mb-2 border-b-2 pb-2" style="border-color: var(--ink); color: var(--ink)">
          Part {roman[part.number - 1]} · {part.title}
        </h2>
        {part.chapters.map((ch) => (
          <a class="ledger-row" href={`/book/${ch.slug}`}>
            <span class="ledger-num">{String(ch.chapterNumber).padStart(2, '0')}</span>
            <span class="ledger-title">{ch.title}</span>
            <span class="ledger-meta">{Math.ceil((ch.words ?? 0) / 200)} min</span>
          </a>
        ))}
      </section>
    ))}

    <p class="ledger-meta mt-12 text-center">
      <a href="/" style="color: var(--green); text-decoration: none">← back to the book’s front page</a>
    </p>
  </main>
</Layout>
